# Copy this file to .env.local and fill in values (never commit .env.local):
#   cp .env.example .env.local

# football-data.org API token (https://www.football-data.org/client/register)
FOOTBALL_DATA_API_KEY=

# Production (VPS / PM2)
NODE_ENV=production
PORT=3000

# Use static schedule + time-based status instead of calling the API (dev/preview)
# NEXT_PUBLIC_USE_MOCK=true

# Preview knockout bracket before June 28
# NEXT_PUBLIC_PREVIEW_BRACKET=true
